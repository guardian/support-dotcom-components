{
	"name": "cdk",
	"version": "0.0.0",
	"private": true,
	"packageManager": "pnpm@9.15.9",
	"scripts": {
		"build": "tsc",
		"test": "jest",
		"test-update": "jest -u",
		"prettier:check": "prettier --check \"{lib,bin}/**/*.ts\"",
		"prettier:fix": "prettier --write \"{lib,bin}/**/*.ts\"",
		"lint": "eslint lib/** bin/** --no-error-on-unmatched-pattern",
		"synth": "cdk synth --path-metadata false --version-reporting false",
		"diff": "cdk diff --path-metadata false --version-reporting false"
	},
	"devDependencies": {
		"@guardian/cdk": "61.3.2",
		"@guardian/eslint-config": "^14.0.0",
		"@guardian/prettier": "10.0.0",
		"@types/jest": "^30.0.0",
		"@types/node": "25.5.0",
		"aws-cdk": "2.1005.0",
		"aws-cdk-lib": "2.189.1",
		"constructs": "10.5.1",
		"eslint": "^9.39.4",
		"globals": "^17.0.0",
		"jest": "^30.3.0",
		"prettier": "^3.7.4",
		"source-map-support": "^0.5.20",
		"ts-jest": "^29.4.6",
		"ts-node": "^10.8.2",
		"typescript": "~5.9.3"
	},
	"prettier": "@guardian/prettier",
	"jest": {
		"testMatch": [
			"<rootDir>/lib/**/*.test.ts"
		],
		"transform": {
			"^.+\\.tsx?$": "ts-jest"
		},
		"setupFilesAfterEnv": [
			"./jest.setup.js"
		]
	},
	"pnpm": {
		"overrides": {
			"minimatch@>=9.0.0 <9.0.7": ">=9.0.7 <10",
			"minimatch@<3.1.4": ">=3.1.4 <4",
			"flatted": "^3.4.2",
			"handlebars@<4.7.9": ">=4.7.9",
			"picomatch@<2.3.2": "2.3.2"
		}
	}
}
