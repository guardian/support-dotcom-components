{
    "name": "@guardian/support-dotcom-components-server",
    "version": "9.0.1",
    "description": "Server for Reader Revenue components",
    "private": true,
    "scripts": {
        "build": "pnpm -w exec esbuild src/server/server.ts --bundle --platform=node --outfile=server-dist/server.js --minify",
        "build:dev": "pnpm -w exec esbuild src/server/server.ts --bundle --platform=node --outfile=server-dist/server.js --sourcemap=inline",
        "start-watch": "pnpm -w exec esbuild src/server/server.ts --bundle --platform=node --outfile=server-dist/server.js --sourcemap=inline --watch",
        "start-server": "stage=DEV PORT=8082 pnpm -w exec nodemon server-dist/server.js"
    },
    "dependencies": {
        "@aws-sdk/client-cloudwatch": "3.1075.0",
        "@aws-sdk/client-dynamodb": "3.1045.0",
        "@aws-sdk/client-s3": "3.1075.0",
        "@aws-sdk/client-ssm": "3.1079.0",
        "@aws-sdk/credential-providers": "3.1045.0",
        "@aws-sdk/lib-dynamodb": "3.1057.0",
        "@okta/jwt-verifier": "4.0.2",
        "compression": "1.8.1",
        "cors": "2.8.6",
        "date-fns": "4.4.0",
        "express": "4.22.1",
        "jsonschema": "1.5.0",
        "lodash.debounce": "4.0.8",
        "lodash.throttle": "4.1.1",
        "log4js": "6.9.1",
        "lru-cache": "11.5.1",
        "seedrandom": "3.0.5"
    },
    "devDependencies": {
        "@types/compression": "1.8.1",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/lodash.debounce": "4.0.9",
        "@types/lodash.throttle": "4.1.9",
        "@types/seedrandom": "3.0.8",
        "esbuild": "0.28.1",
        "nodemon": "3.1.14"
    }
}
